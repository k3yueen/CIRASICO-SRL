# Auto-detect text files and normalize line endings
* text=auto

# Enforce LF for source/text files
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.php  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Keep CRLF for Windows scripts
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary files (no EOL conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.svg  binary
